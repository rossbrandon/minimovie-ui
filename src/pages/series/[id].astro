---
import { SeasonCard } from '@components/cards';
import {
  IconAlertCircle,
  IconAntenna,
  IconCalendar,
  IconClock,
  IconStar,
  IconVideo,
} from '@components/icons';
import { Header } from '@components/layout';
import {
  AccordionSearch,
  CrewGrid,
  KeyCrew,
  TopCast,
  WhereToWatch,
} from '@components/sections';
import {
  Accordion,
  AccordionCloseButton,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from '@components/starwind/accordion';
import { Badge } from '@components/starwind/badge';
import { Button } from '@components/starwind/button';
import { Separator } from '@components/starwind/separator';
import Layout from '@layouts/Layout.astro';
import { getSeries } from '@lib/api';
import type { SeriesDetails } from '@lib/types';
import {
  formatAgeDisplay,
  formatDate,
  formatRating,
  formatRuntime,
  formatYearsAgo,
} from '@lib/utils';

const { id } = Astro.params;

let series: SeriesDetails | null = null;
let error: string | null = null;

try {
  series = await getSeries(Number(id));
} catch (e) {
  console.error('Failed to fetch series:', e);
  error = 'Failed to load series details.';
}

// TODO: 250 is a placeholder limit due to Cloudflare free tier limits
// We should have a "show all" button that will load the full cast.
const cast = series?.credits?.cast?.slice(0, 250) || [];
const seasons = series?.seasons?.filter((s) => s.seasonNumber > 0) || [];
const rating = formatRating(series?.voteAverage);

const keyCrewEntries = [
  { label: 'Creator', person: series?.createdBy?.[0] },
  { label: 'Director', person: series?.credits?.directors?.[0] },
  { label: 'Writer', person: series?.credits?.writers?.[0] },
  { label: 'Producer', person: series?.credits?.producers?.[0] },
];

const avgRuntime = series?.episodeRunTime?.[0];
---

<Layout title={series ? `${series.name} - MiniMovie` : 'Series - MiniMovie'}>
  <Header />

  <main class="container mx-auto px-4 py-8 flex-1">
    {
      error || !series ? (
        <div class="text-center py-16">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-error/10 text-error mb-4">
            <IconAlertCircle class="h-8 w-8" />
          </div>
          <h1 class="text-2xl font-semibold mb-2">Series not found</h1>
          <p class="text-muted-foreground mb-6">
            {error || "The series you're looking for doesn't exist."}
          </p>
          <Button href="/" variant="outline">
            Back to Home
          </Button>
        </div>
      ) : (
        <div class="space-y-8">
          {/* Hero Section */}
          <div class="flex flex-col md:flex-row gap-8">
            {/* Poster */}
            <div class="shrink-0 mx-auto md:mx-0">
              <div class="w-64 aspect-2/3 overflow-hidden rounded-lg bg-muted shadow-lg">
                {series.posterUrl ? (
                  <img
                    src={series.posterUrl}
                    alt={series.name}
                    class="h-full w-full object-cover"
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center text-4xl font-semibold text-muted-foreground">
                    {series.name.charAt(0)}
                  </div>
                )}
              </div>
            </div>

            {/* Info */}
            <div class="flex-1 space-y-4">
              <div>
                <h1 class="text-3xl md:text-4xl font-bold">{series.name}</h1>
                {series.tagline && (
                  <p class="text-lg text-muted-foreground italic mt-1">
                    "{series.tagline}"
                  </p>
                )}
              </div>

              {/* Genres */}
              {series.genres && series.genres.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {series.genres.map((genre) => (
                    <Badge variant="outline">{genre}</Badge>
                  ))}
                </div>
              )}

              {/* Metadata */}
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted-foreground">
                {series.firstAirDate && (
                  <div class="flex items-center gap-1.5">
                    <IconCalendar class="h-4 w-4" />
                    <span>
                      {formatDate(series.firstAirDate)}
                      {series.lastAirDate &&
                        series.lastAirDate !== series.firstAirDate && (
                          <span> – {formatDate(series.lastAirDate)}</span>
                        )}
                    </span>
                    {formatYearsAgo(series.firstAirDate) && (
                      <span class="text-muted-foreground/60">
                        (began {formatYearsAgo(series.firstAirDate)})
                      </span>
                    )}
                  </div>
                )}
                {avgRuntime && (
                  <div class="flex items-center gap-1.5">
                    <IconClock class="h-4 w-4" />
                    <span>{formatRuntime(avgRuntime)} / episode</span>
                  </div>
                )}
                {rating && (
                  <div class="flex items-center gap-1.5 text-amber-500">
                    <IconStar class="h-4 w-4" />
                    <span>{rating}</span>
                  </div>
                )}
                {series.status && (
                  <Badge
                    variant={
                      series.status === 'Ended'
                        ? 'ghost'
                        : series.inProduction
                          ? 'info'
                          : 'default'
                    }
                    class="text-xs"
                  >
                    {series.status}
                  </Badge>
                )}
              </div>

              {/* Season/Episode Counts */}
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm">
                {series.numberOfSeasons && (
                  <div class="flex items-center gap-1.5 text-muted-foreground">
                    <span class="font-semibold text-foreground">
                      {series.numberOfSeasons}
                    </span>
                    <span>
                      {series.numberOfSeasons === 1 ? 'Season' : 'Seasons'}
                    </span>
                  </div>
                )}
                {series.numberOfEpisodes && (
                  <div class="flex items-center gap-1.5 text-muted-foreground">
                    <IconVideo class="h-4 w-4" />
                    <span class="font-semibold text-foreground">
                      {series.numberOfEpisodes}
                    </span>
                    <span>Episodes</span>
                  </div>
                )}
              </div>

              {/* Networks */}
              {series.networks && series.networks.length > 0 && (
                <div class="flex flex-wrap items-center gap-3">
                  {series.networks.map((network) => (
                    <div class="flex items-center gap-2 rounded-lg bg-muted px-3 py-1.5">
                      {network.logoUrl ? (
                        <img
                          src={network.logoUrl}
                          alt={network.name}
                          class="h-5 w-auto max-w-[60px] object-contain"
                          loading="lazy"
                        />
                      ) : (
                        <>
                          <IconAntenna class="h-4 w-4 text-muted-foreground" />
                          <span class="text-sm">{network.name}</span>
                        </>
                      )}
                    </div>
                  ))}
                </div>
              )}

              {/* Overview */}
              <div class="space-y-2">
                <p class="text-foreground leading-relaxed">
                  {series.overview || 'No overview available.'}
                </p>
              </div>

              <KeyCrew entries={keyCrewEntries} />
            </div>
          </div>

          <TopCast cast={cast} />

          <Separator />

          {/* Accordion Sections */}
          <Accordion type="multiple" class="space-y-2">
            {/* Seasons */}
            {seasons.length > 0 && (
              <AccordionItem
                value="seasons"
                class="rounded-lg border border-border bg-card px-4 last:border-b"
              >
                <AccordionTrigger>
                  <span class="text-lg font-medium">
                    Seasons ({seasons.length})
                  </span>
                </AccordionTrigger>
                <AccordionContent>
                  <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                    {seasons.map((season) => (
                      <SeasonCard
                        seriesId={series.id}
                        seasonNumber={season.seasonNumber}
                        name={season.name}
                        posterUrl={season.posterUrl}
                        episodeCount={season.episodeCount}
                        airDate={season.airDate}
                        overview={season.overview}
                        prefetch={true}
                      />
                    ))}
                  </div>
                </AccordionContent>
              </AccordionItem>
            )}

            {/* Where to Watch */}
            {series.whereToWatch && (
              <AccordionItem
                value="where-to-watch"
                class="rounded-lg border border-border bg-card px-4 last:border-b"
              >
                <AccordionTrigger>
                  <span class="text-lg font-medium">Where to Watch</span>
                </AccordionTrigger>
                <AccordionContent>
                  <WhereToWatch whereToWatch={series.whereToWatch} />
                </AccordionContent>
              </AccordionItem>
            )}

            {/* Full Cast & Crew */}
            {cast.length > 0 && (
              <AccordionItem
                value="full-cast"
                class="rounded-lg border border-border bg-card px-4 last:border-b"
              >
                <AccordionTrigger>
                  <span class="text-lg font-medium">Full Cast & Crew</span>
                </AccordionTrigger>
                <AccordionContent>
                  <div class="space-y-6">
                    <AccordionSearch />

                    {/* Full Cast */}
                    <div>
                      <h3 class="text-sm font-medium text-muted-foreground mb-3">
                        Cast ({cast.length})
                      </h3>
                      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
                        {cast.map((person) => (
                          <a
                            href={`/people/${person.id}`}
                            class="group flex items-center gap-3 p-2 rounded-lg hover:bg-muted/50 transition-colors"
                          >
                            <div class="h-10 w-10 shrink-0 overflow-hidden rounded-lg bg-muted">
                              {person.photoUrl ? (
                                <img
                                  src={person.photoUrl}
                                  alt={person.name}
                                  class="h-full w-full object-cover"
                                  loading="lazy"
                                />
                              ) : (
                                <div class="flex h-full w-full items-center justify-center text-xs font-semibold text-muted-foreground">
                                  {person.name.charAt(0)}
                                </div>
                              )}
                            </div>
                            <div class="min-w-0 flex-1">
                              <p class="font-medium text-sm truncate group-hover:text-amber-500 transition-colors">
                                {person.name}
                              </p>
                              {person.role && (
                                <p class="text-xs text-muted-foreground truncate">
                                  {person.role}
                                </p>
                              )}
                              {formatAgeDisplay(person) && (
                                <p class="text-xs text-muted-foreground/70">
                                  {formatAgeDisplay(person)}
                                </p>
                              )}
                            </div>
                          </a>
                        ))}
                      </div>
                    </div>

                    <CrewGrid
                      title="Directors"
                      people={series.credits?.directors || []}
                    />
                    <CrewGrid
                      title="Writers"
                      people={series.credits?.writers || []}
                    />
                    <CrewGrid
                      title="Producers"
                      people={series.credits?.producers || []}
                    />
                    <CrewGrid
                      title="Composers"
                      people={series.credits?.composers || []}
                    />
                    <CrewGrid
                      title="Cinematographers"
                      people={series.credits?.cinematographers || []}
                    />
                    <CrewGrid
                      title="Editors"
                      people={series.credits?.editors || []}
                    />

                    <AccordionCloseButton label="Close Cast & Crew" />
                  </div>
                </AccordionContent>
              </AccordionItem>
            )}

            {/* More Info */}
            <AccordionItem
              value="more-info"
              class="rounded-lg border border-border bg-card px-4 last:border-b"
            >
              <AccordionTrigger>
                <span class="text-lg font-medium">More Info</span>
              </AccordionTrigger>
              <AccordionContent>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                  {series.originalName &&
                    series.originalName !== series.name && (
                      <div>
                        <p class="text-muted-foreground">Original Name</p>
                        <p class="font-medium">{series.originalName}</p>
                      </div>
                    )}
                  {series.originalLanguage && (
                    <div>
                      <p class="text-muted-foreground">Original Language</p>
                      <p class="font-medium uppercase">
                        {series.originalLanguage}
                      </p>
                    </div>
                  )}
                  {series.spokenLanguages &&
                    series.spokenLanguages.length > 0 && (
                      <div>
                        <p class="text-muted-foreground">Spoken Languages</p>
                        <p class="font-medium">
                          {series.spokenLanguages.join(', ')}
                        </p>
                      </div>
                    )}
                  {series.productionCountries &&
                    series.productionCountries.length > 0 && (
                      <div>
                        <p class="text-muted-foreground">
                          Production Countries
                        </p>
                        <p class="font-medium">
                          {series.productionCountries.join(', ')}
                        </p>
                      </div>
                    )}
                  {series.productionCompanies &&
                    series.productionCompanies.length > 0 && (
                      <div class="md:col-span-2">
                        <p class="text-muted-foreground">
                          Production Companies
                        </p>
                        <p class="font-medium">
                          {series.productionCompanies.join(', ')}
                        </p>
                      </div>
                    )}
                </div>
              </AccordionContent>
            </AccordionItem>
          </Accordion>
        </div>
      )
    }
  </main>
</Layout>
