---
import {
  IconAlertCircle,
  IconCalendar,
  IconClock,
  IconStar,
} from '@components/icons';
import { Breadcrumbs, Header } from '@components/layout';
import { CrewGrid, KeyCrew, TopCast } from '@components/sections';
import {
  Accordion,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from '@components/starwind/accordion';
import { Badge } from '@components/starwind/badge';
import { Button } from '@components/starwind/button';
import { Separator } from '@components/starwind/separator';
import Layout from '@layouts/Layout.astro';
import { getEpisode, getSeries } from '@lib/api';
import type { EpisodeDetails, SeriesDetails } from '@lib/types';
import {
  formatAgeDisplay,
  formatDate,
  formatEpisodeCode,
  formatRating,
  formatRuntime,
  formatYearsAgo,
  resizeImageUrl,
} from '@lib/utils';

const { seriesId, seasonNumber, episodeNumber } = Astro.params;

let episode: EpisodeDetails | null = null;
let series: SeriesDetails | null = null;
let error: string | null = null;

try {
  [episode, series] = await Promise.all([
    getEpisode(Number(seriesId), Number(seasonNumber), Number(episodeNumber)),
    getSeries(Number(seriesId)),
  ]);
} catch (e) {
  console.error('Failed to fetch episode:', e);
  error = 'Failed to load episode details.';
}

const guestStars = episode?.guestStars || [];
const cast = episode?.credits?.cast || [];
const rating = formatRating(episode?.voteAverage);
const episodeCode = episode
  ? formatEpisodeCode(episode.seasonNumber, episode.episodeNumber)
  : '';

const seasonName =
  series?.seasons?.find((s) => s.seasonNumber === Number(seasonNumber))?.name ||
  `Season ${seasonNumber}`;

const stillUrl = resizeImageUrl(episode?.stillUrl, 'original');

const keyCrewEntries = [
  { label: 'Director', person: episode?.credits?.directors?.[0] },
  { label: 'Writer', person: episode?.credits?.writers?.[0] },
];

const breadcrumbItems =
  series && episode
    ? [
        { label: series.name, href: `/series/${seriesId}` },
        {
          label: seasonName,
          href: `/series/${seriesId}/seasons/${seasonNumber}`,
        },
        { label: `Episode ${episode.episodeNumber}` },
      ]
    : [];

const searchQuery = series?.name;
---

<Layout
  title={episode && series
    ? `${episodeCode}: ${episode.name} - ${series.name} - MiniMovie`
    : 'Episode - MiniMovie'}
>
  <Header />

  <main class="container mx-auto px-4 py-8 flex-1">
    {
      error || !episode ? (
        <div class="text-center py-16">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-error/10 text-error mb-4">
            <IconAlertCircle class="h-8 w-8" />
          </div>
          <h1 class="text-2xl font-semibold mb-2">Episode not found</h1>
          <p class="text-muted-foreground mb-6">
            {error || "The episode you're looking for doesn't exist."}
          </p>
          <Button href="/" variant="outline">
            Back to Home
          </Button>
        </div>
      ) : (
        <div class="space-y-8">
          <Breadcrumbs items={breadcrumbItems} searchQuery={searchQuery} />

          {/* Hero Section */}
          <div class="flex flex-col md:flex-row gap-8">
            {/* Episode Still (landscape) */}
            <div class="shrink-0 w-full md:w-96">
              <div class="aspect-video overflow-hidden rounded-lg bg-muted shadow-lg">
                {stillUrl ? (
                  <img
                    src={stillUrl}
                    alt={episode.name}
                    class="h-full w-full object-cover"
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center text-2xl font-semibold text-muted-foreground">
                    {episodeCode}
                  </div>
                )}
              </div>
            </div>

            {/* Info */}
            <div class="flex-1 space-y-4">
              <div>
                <div class="flex items-center gap-2 mb-2">
                  <Badge variant="outline" class="text-xs">
                    {episodeCode}
                  </Badge>
                  {rating && (
                    <div class="flex items-center gap-1 text-amber-500 text-sm">
                      <IconStar class="h-4 w-4" />
                      <span>{rating}</span>
                    </div>
                  )}
                </div>
                <h1 class="text-3xl md:text-4xl font-bold">{episode.name}</h1>
                {series && (
                  <p class="text-muted-foreground mt-1">{series.name}</p>
                )}
              </div>

              {/* Metadata */}
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted-foreground">
                {episode.airDate && (
                  <div class="flex items-center gap-1.5">
                    <IconCalendar class="h-4 w-4" />
                    <span>{formatDate(episode.airDate)}</span>
                    {formatYearsAgo(episode.airDate) && (
                      <span class="text-muted-foreground/60">
                        ({formatYearsAgo(episode.airDate)})
                      </span>
                    )}
                  </div>
                )}
                {episode.runtime && (
                  <div class="flex items-center gap-1.5">
                    <IconClock class="h-4 w-4" />
                    <span>{formatRuntime(episode.runtime)}</span>
                  </div>
                )}
              </div>

              {/* Overview */}
              <div class="space-y-2">
                <p class="text-foreground leading-relaxed">
                  {episode.overview || 'No overview available.'}
                </p>
              </div>

              <KeyCrew entries={keyCrewEntries} />
            </div>
          </div>

          <TopCast cast={cast} />

          <Separator />

          {/* Accordion Sections */}
          <Accordion type="multiple" class="space-y-2">
            {/* Guest Stars */}
            {guestStars.length > 0 && (
              <AccordionItem
                value="guest-stars"
                class="rounded-lg border border-border bg-card px-4 last:border-b"
              >
                <AccordionTrigger>
                  <span class="text-lg font-medium">
                    Guest Stars ({guestStars.length})
                  </span>
                </AccordionTrigger>
                <AccordionContent>
                  <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
                    {guestStars.map((person) => (
                      <a
                        href={`/people/${person.id}`}
                        class="group flex items-center gap-3 p-2 rounded-lg hover:bg-muted/50 transition-colors"
                      >
                        <div class="h-10 w-10 shrink-0 overflow-hidden rounded-lg bg-muted">
                          {person.photoUrl ? (
                            <img
                              src={person.photoUrl}
                              alt={person.name}
                              class="h-full w-full object-cover"
                              loading="lazy"
                            />
                          ) : (
                            <div class="flex h-full w-full items-center justify-center text-xs font-semibold text-muted-foreground">
                              {person.name.charAt(0)}
                            </div>
                          )}
                        </div>
                        <div class="min-w-0 flex-1">
                          <p class="font-medium text-sm truncate group-hover:text-amber-500 transition-colors">
                            {person.name}
                          </p>
                          {person.role && (
                            <p class="text-xs text-muted-foreground truncate">
                              {person.role}
                            </p>
                          )}
                        </div>
                      </a>
                    ))}
                  </div>
                </AccordionContent>
              </AccordionItem>
            )}

            {/* Cast & Crew */}
            {(cast.length > 0 || episode.credits) && (
              <AccordionItem
                value="cast-crew"
                class="rounded-lg border border-border bg-card px-4 last:border-b"
              >
                <AccordionTrigger>
                  <span class="text-lg font-medium">Cast & Crew</span>
                </AccordionTrigger>
                <AccordionContent>
                  <div class="space-y-6">
                    {/* Full Cast */}
                    {cast.length > 0 && (
                      <div>
                        <h3 class="text-sm font-medium text-muted-foreground mb-3">
                          Cast ({cast.length})
                        </h3>
                        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
                          {cast.map((person) => (
                            <a
                              href={`/people/${person.id}`}
                              class="group flex items-center gap-3 p-2 rounded-lg hover:bg-muted/50 transition-colors"
                            >
                              <div class="h-10 w-10 shrink-0 overflow-hidden rounded-lg bg-muted">
                                {person.photoUrl ? (
                                  <img
                                    src={person.photoUrl}
                                    alt={person.name}
                                    class="h-full w-full object-cover"
                                    loading="lazy"
                                  />
                                ) : (
                                  <div class="flex h-full w-full items-center justify-center text-xs font-semibold text-muted-foreground">
                                    {person.name.charAt(0)}
                                  </div>
                                )}
                              </div>
                              <div class="min-w-0 flex-1">
                                <p class="font-medium text-sm truncate group-hover:text-amber-500 transition-colors">
                                  {person.name}
                                </p>
                                {person.role && (
                                  <p class="text-xs text-muted-foreground truncate">
                                    {person.role}
                                  </p>
                                )}
                                {formatAgeDisplay(person) && (
                                  <p class="text-xs text-muted-foreground/70">
                                    {formatAgeDisplay(person)}
                                  </p>
                                )}
                              </div>
                            </a>
                          ))}
                        </div>
                      </div>
                    )}

                    <CrewGrid
                      title="Directors"
                      people={episode.credits?.directors || []}
                    />
                    <CrewGrid
                      title="Writers"
                      people={episode.credits?.writers || []}
                    />
                    <CrewGrid
                      title="Producers"
                      people={episode.credits?.producers || []}
                    />
                    <CrewGrid
                      title="Cinematographers"
                      people={episode.credits?.cinematographers || []}
                    />
                    <CrewGrid
                      title="Editors"
                      people={episode.credits?.editors || []}
                    />
                  </div>
                </AccordionContent>
              </AccordionItem>
            )}
          </Accordion>
        </div>
      )
    }
  </main>
</Layout>
