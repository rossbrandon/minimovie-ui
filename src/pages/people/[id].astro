---
import { CreditCard } from '@components/cards';
import {
  IconAlertCircle,
  IconCake,
  IconDeviceTv,
  IconInfoCircle,
  IconMapPin,
  IconMovie,
  IconStar,
  IconUser,
} from '@components/icons';
import { Header } from '@components/layout';
import { SectionSearch } from '@components/sections';
import { Button } from '@components/starwind/button';
import {
  Tabs,
  TabsContent,
  TabsList,
  TabsTrigger,
} from '@components/starwind/tabs';
import Layout from '@layouts/Layout.astro';
import { getPerson } from '@lib/api';
import type { FilmCredit, PersonDetails } from '@lib/types';
import { formatPersonAge, getInitials, resizeImageUrl } from '@lib/utils';

const { id } = Astro.params;

let person: PersonDetails | null = null;
let error: string | null = null;

try {
  person = await getPerson(Number(id));
} catch (e) {
  console.error('Failed to fetch person:', e);
  error = 'Failed to load person details.';
}

const movieCredits = person?.movieCredits || [];
const seriesCredits = person?.seriesCredits || [];

const sortByDate = (a: FilmCredit, b: FilmCredit) => {
  if (!a.releaseDate && !b.releaseDate) return 0;
  if (!a.releaseDate) return 1;
  if (!b.releaseDate) return -1;
  return new Date(b.releaseDate).getTime() - new Date(a.releaseDate).getTime();
};

const sortByOrder = (a: FilmCredit, b: FilmCredit) => {
  if (a.order == null && b.order == null) {
    return (b.popularity ?? 0) - (a.popularity ?? 0);
  }
  if (a.order == null) return 1;
  if (b.order == null) return -1;
  return a.order - b.order;
};

const sortedMovieCredits = [...movieCredits].sort(sortByDate);
const sortedSeriesCredits = [...seriesCredits].sort(sortByDate);

const knownFor = [...movieCredits, ...seriesCredits]
  .sort(sortByOrder)
  .slice(0, 16);

const ageInfo = person
  ? formatPersonAge(person.birthday, person.deathday, person.currentAge)
  : null;

const photoUrl = resizeImageUrl(person?.photoUrl, 'h632');

const tabValues = [
  knownFor.length > 0 && 'known-for',
  sortedMovieCredits.length > 0 && 'movies',
  sortedSeriesCredits.length > 0 && 'series',
  'more-info',
].filter(Boolean) as string[];

const requestedTab = Astro.url.searchParams.get('tab');
const defaultTab =
  requestedTab && tabValues.includes(requestedTab)
    ? requestedTab
    : tabValues[0];
---

<Layout title={person ? `${person.name} - MiniMovie` : 'Person - MiniMovie'}>
  <Header />

  <main class="container mx-auto px-4 py-8 flex-1">
    {
      error || !person ? (
        <div class="text-center py-16">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-error/10 text-error mb-4">
            <IconAlertCircle class="h-8 w-8" />
          </div>
          <h1 class="text-2xl font-semibold mb-2">Person not found</h1>
          <p class="text-muted-foreground mb-6">
            {error || "The person you're looking for doesn't exist."}
          </p>
          <Button href="/" variant="outline">
            Back to Home
          </Button>
        </div>
      ) : (
        <div class="space-y-8">
          {/* Hero Section */}
          <div class="flex flex-col md:flex-row gap-8">
            {/* Photo */}
            <div class="shrink-0 mx-auto md:mx-0">
              <div class="w-64 aspect-2/3 overflow-hidden rounded-lg bg-muted shadow-lg">
                {photoUrl ? (
                  <img
                    src={photoUrl}
                    alt={person.name}
                    class="h-full w-full object-cover"
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center text-4xl font-semibold text-muted-foreground">
                    {getInitials(person.name)}
                  </div>
                )}
              </div>
            </div>

            {/* Info */}
            <div class="flex-1 space-y-4">
              <div>
                <h1 class="text-3xl md:text-4xl font-bold">{person.name}</h1>
                {person.knownFor && (
                  <p class="text-lg text-muted-foreground mt-1">
                    {person.knownFor}
                  </p>
                )}
              </div>

              {/* Personal Details */}
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted-foreground">
                {ageInfo && (
                  <div class="flex items-center gap-1.5">
                    <IconCake class="h-4 w-4" />
                    <span>{ageInfo}</span>
                  </div>
                )}
                {person.placeOfBirth && (
                  <div class="flex items-center gap-1.5">
                    <IconMapPin class="h-4 w-4" />
                    <span>{person.placeOfBirth}</span>
                  </div>
                )}
                {person.gender && person.gender !== 'Not specified' && (
                  <div class="flex items-center gap-1.5">
                    <IconUser class="h-4 w-4" />
                    <span>{person.gender}</span>
                  </div>
                )}
              </div>
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted-foreground">
                {movieCredits.length > 0 && (
                  <div class="flex items-center gap-1.5">
                    <IconMovie class="h-4 w-4" />
                    <span>{movieCredits.length} Movies</span>
                  </div>
                )}
                {seriesCredits.length > 0 && (
                  <div class="flex items-center gap-1.5">
                    <IconDeviceTv class="h-4 w-4" />
                    <span>{seriesCredits.length} TV Shows</span>
                  </div>
                )}
              </div>

              {/* Biography */}
              {person.biography && (
                <div class="space-y-2">
                  <p class="text-foreground leading-relaxed whitespace-pre-line">
                    {person.biography}
                  </p>
                </div>
              )}
            </div>
          </div>

          <Tabs defaultValue={defaultTab}>
            <TabsList>
              {knownFor.length > 0 && (
                <TabsTrigger value="known-for">
                  <IconStar class="size-4" /> Known For
                </TabsTrigger>
              )}
              {sortedMovieCredits.length > 0 && (
                <TabsTrigger value="movies">
                  <IconMovie class="size-4" /> Movies
                  <span class="text-xs text-muted-foreground">
                    {sortedMovieCredits.length}
                  </span>
                </TabsTrigger>
              )}
              {sortedSeriesCredits.length > 0 && (
                <TabsTrigger value="series">
                  <IconDeviceTv class="size-4" /> TV Series
                  <span class="text-xs text-muted-foreground">
                    {sortedSeriesCredits.length}
                  </span>
                </TabsTrigger>
              )}
              <TabsTrigger value="more-info">
                <IconInfoCircle class="size-4" /> More Info
              </TabsTrigger>
            </TabsList>

            {knownFor.length > 0 && (
              <TabsContent value="known-for">
                <div class="grid grid-cols-[repeat(auto-fill,minmax(140px,1fr))] gap-4">
                  {knownFor.map((credit) => (
                    <CreditCard
                      credit={credit}
                      mediaType={
                        movieCredits.includes(credit) ? 'movie' : 'series'
                      }
                      voteAverage={credit.voteAverage}
                      personBirthday={person.birthday}
                      personDeathday={person.deathday}
                      personCurrentAge={person.currentAge}
                      prefetch={true}
                    />
                  ))}
                </div>
              </TabsContent>
            )}

            {sortedMovieCredits.length > 0 && (
              <TabsContent value="movies">
                <div class="space-y-4">
                  <SectionSearch placeholder="Search movies..." />
                  <div class="grid grid-cols-[repeat(auto-fill,minmax(140px,1fr))] gap-4">
                    {sortedMovieCredits.map((credit) => (
                      <CreditCard
                        credit={credit}
                        mediaType="movie"
                        voteAverage={credit.voteAverage}
                        personBirthday={person.birthday}
                        personDeathday={person.deathday}
                        personCurrentAge={person.currentAge}
                      />
                    ))}
                  </div>
                </div>
              </TabsContent>
            )}

            {sortedSeriesCredits.length > 0 && (
              <TabsContent value="series">
                <div class="space-y-4">
                  <SectionSearch placeholder="Search series..." />
                  <div class="grid grid-cols-[repeat(auto-fill,minmax(140px,1fr))] gap-4">
                    {sortedSeriesCredits.map((credit) => (
                      <CreditCard
                        credit={credit}
                        mediaType="series"
                        voteAverage={credit.voteAverage}
                        personBirthday={person.birthday}
                        personDeathday={person.deathday}
                        personCurrentAge={person.currentAge}
                      />
                    ))}
                  </div>
                </div>
              </TabsContent>
            )}

            <TabsContent value="more-info">
              <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                {person.alsoKnownAs && person.alsoKnownAs.length > 0 && (
                  <div class="md:col-span-2">
                    <p class="text-muted-foreground">Also Known As</p>
                    <p class="font-medium">{person.alsoKnownAs.join(', ')}</p>
                  </div>
                )}
                {person.imdbId && (
                  <div>
                    <p class="text-muted-foreground">IMDB</p>
                    <a
                      href={`https://www.imdb.com/name/${person.imdbId}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="font-medium text-primary hover:underline"
                    >
                      {person.imdbId}
                    </a>
                  </div>
                )}
              </div>
            </TabsContent>
          </Tabs>
        </div>
      )
    }
  </main>
</Layout>
