---
import {
  IconAlertCircle,
  IconCalendar,
  IconClock,
  IconStar,
  IconTrendingDown,
  IconTrendingUp,
} from '@components/icons';
import { Header } from '@components/layout';
import { CrewGrid, TopCast, WhereToWatch } from '@components/sections';
import {
  Accordion,
  AccordionCloseButton,
  AccordionContent,
  AccordionItem,
  AccordionTrigger,
} from '@components/starwind/accordion';
import { Badge } from '@components/starwind/badge';
import { Button } from '@components/starwind/button';
import { Separator } from '@components/starwind/separator';
import Layout from '@layouts/Layout.astro';
import { getMovie } from '@lib/api';
import type { MovieDetails } from '@lib/types';
import {
  formatAgeDisplay,
  formatCurrency,
  formatDate,
  formatProfit,
  formatRating,
  formatRuntime,
  formatYearsAgo,
} from '@lib/utils';

const { id } = Astro.params;

let movie: MovieDetails | null = null;
let error: string | null = null;

try {
  movie = await getMovie(Number(id));
} catch (e) {
  console.error('Failed to fetch movie:', e);
  error = 'Failed to load movie details.';
}

const profit = movie ? formatProfit(movie.budget, movie.revenue) : null;
const rating = formatRating(movie?.voteAverage);

const cast = movie?.credits?.cast || [];

const director = movie?.credits?.directors?.[0];
const writer = movie?.credits?.writers?.[0];
const producer = movie?.credits?.producers?.[0];
const cinematographer = movie?.credits?.cinematographers?.[0];
---

<Layout title={movie ? `${movie.title} - MiniMovie` : 'Movie - MiniMovie'}>
  <Header />

  <main class="container mx-auto px-4 py-8 flex-1">
    {
      error || !movie ? (
        <div class="text-center py-16">
          <div class="inline-flex items-center justify-center w-16 h-16 rounded-full bg-error/10 text-error mb-4">
            <IconAlertCircle class="h-8 w-8" />
          </div>
          <h1 class="text-2xl font-semibold mb-2">Movie not found</h1>
          <p class="text-muted-foreground mb-6">
            {error || "The movie you're looking for doesn't exist."}
          </p>
          <Button href="/" variant="outline">
            Back to Home
          </Button>
        </div>
      ) : (
        <div class="space-y-8">
          {/* Hero Section */}
          <div class="flex flex-col md:flex-row gap-8">
            {/* Poster */}
            <div class="shrink-0 mx-auto md:mx-0">
              <div class="w-64 aspect-2/3 overflow-hidden rounded-lg bg-muted shadow-lg">
                {movie.posterUrl ? (
                  <img
                    src={movie.posterUrl}
                    alt={movie.title}
                    class="h-full w-full object-cover"
                  />
                ) : (
                  <div class="flex h-full w-full items-center justify-center text-4xl font-semibold text-muted-foreground">
                    {movie.title.charAt(0)}
                  </div>
                )}
              </div>
            </div>

            {/* Info */}
            <div class="flex-1 space-y-4">
              <div>
                <h1 class="text-3xl md:text-4xl font-bold">{movie.title}</h1>
                {movie.tagline && (
                  <p class="text-lg text-muted-foreground italic mt-1">
                    "{movie.tagline}"
                  </p>
                )}
              </div>

              {/* Genres */}
              {movie.genres && movie.genres.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {movie.genres.map((genre) => (
                    <Badge variant="outline">{genre}</Badge>
                  ))}
                </div>
              )}

              {/* Metadata */}
              <div class="flex flex-wrap items-center gap-x-4 gap-y-2 text-sm text-muted-foreground">
                {movie.releaseDate && (
                  <div class="flex items-center gap-1.5">
                    <IconCalendar class="h-4 w-4" />
                    <span>{formatDate(movie.releaseDate)}</span>
                    {formatYearsAgo(movie.releaseDate) && (
                      <span class="text-muted-foreground/60">
                        ({formatYearsAgo(movie.releaseDate)})
                      </span>
                    )}
                  </div>
                )}
                {movie.runtime !== undefined && movie.runtime > 0 && (
                  <div class="flex items-center gap-1.5">
                    <IconClock class="h-4 w-4" />
                    <span>{formatRuntime(movie.runtime)}</span>
                  </div>
                )}
                {rating && (
                  <div class="flex items-center gap-1.5 text-amber-500">
                    <IconStar class="h-4 w-4" />
                    <span>{rating}</span>
                  </div>
                )}
                {movie.status && movie.status !== 'Released' && (
                  <Badge variant="info" class="text-xs">
                    {movie.status}
                  </Badge>
                )}
              </div>

              {/* Overview */}
              <div class="space-y-2">
                <p class="text-foreground leading-relaxed">
                  {movie.overview || 'No overview available.'}
                </p>
              </div>

              {/* Box Office & Key Crew */}
              <div class="grid grid-cols-1 lg:grid-cols-2 gap-4">
                {/* Box Office */}
                {movie.budget !== undefined || movie.revenue !== undefined ? (
                  <div class="rounded-lg bg-card border border-border p-4">
                    <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-3">
                      Box Office
                    </h3>
                    <div class="flex flex-wrap gap-x-6 gap-y-3">
                      <div class="min-w-[80px]">
                        <p class="text-xs text-muted-foreground">Budget</p>
                        <p class="font-semibold font-mono text-sm sm:text-base">
                          {movie.budget
                            ? formatCurrency(movie.budget)
                            : 'Unknown'}
                        </p>
                      </div>
                      <div class="min-w-[80px]">
                        <p class="text-xs text-muted-foreground">Revenue</p>
                        <p class="font-semibold font-mono text-sm sm:text-base">
                          {movie.revenue
                            ? formatCurrency(movie.revenue)
                            : 'Unknown'}
                        </p>
                      </div>
                      {profit ? (
                        <div class="min-w-[80px]">
                          <p class="text-xs text-muted-foreground">
                            Profit/Loss
                          </p>
                          <p
                            class={`font-semibold font-mono text-sm sm:text-base flex items-center gap-1 ${profit.isProfit ? 'text-emerald-500' : 'text-red-500'}`}
                          >
                            {profit.isProfit ? (
                              <IconTrendingUp class="h-4 w-4" />
                            ) : (
                              <IconTrendingDown class="h-4 w-4" />
                            )}
                            {profit.isProfit ? '+' : '-'}
                            {profit.amount}
                          </p>
                        </div>
                      ) : null}
                    </div>
                  </div>
                ) : null}

                {/* Key Crew */}
                {(director || writer || producer || cinematographer) && (
                  <div class="rounded-lg bg-card border border-border p-4">
                    <h3 class="text-xs font-medium text-muted-foreground uppercase tracking-wide mb-3">
                      Key Crew
                    </h3>
                    <div class="grid grid-cols-2 gap-4 text-sm">
                      {director && (
                        <a
                          href={`/people/${director.id}`}
                          class="group flex items-center gap-3 rounded-lg p-1 -m-1 hover:bg-muted/50 transition-colors"
                        >
                          <div class="h-10 w-10 shrink-0 overflow-hidden rounded-lg bg-muted">
                            {director.photoUrl ? (
                              <img
                                src={director.photoUrl}
                                alt={director.name}
                                class="h-full w-full object-cover"
                                loading="lazy"
                              />
                            ) : (
                              <div class="flex h-full w-full items-center justify-center text-xs font-semibold text-muted-foreground">
                                {director.name.charAt(0)}
                              </div>
                            )}
                          </div>
                          <div>
                            <p class="text-xs text-muted-foreground">
                              Director
                            </p>
                            <p class="font-medium text-sm group-hover:text-amber-500 transition-colors">
                              {director.name}
                            </p>
                            {formatAgeDisplay(director) && (
                              <p class="text-xs text-muted-foreground/70">
                                {formatAgeDisplay(director)}
                              </p>
                            )}
                          </div>
                        </a>
                      )}
                      {producer && (
                        <a
                          href={`/people/${producer.id}`}
                          class="group flex items-center gap-3 rounded-lg p-1 -m-1 hover:bg-muted/50 transition-colors"
                        >
                          <div class="h-10 w-10 shrink-0 overflow-hidden rounded-lg bg-muted">
                            {producer.photoUrl ? (
                              <img
                                src={producer.photoUrl}
                                alt={producer.name}
                                class="h-full w-full object-cover"
                                loading="lazy"
                              />
                            ) : (
                              <div class="flex h-full w-full items-center justify-center text-xs font-semibold text-muted-foreground">
                                {producer.name.charAt(0)}
                              </div>
                            )}
                          </div>
                          <div>
                            <p class="text-xs text-muted-foreground">
                              Producer
                            </p>
                            <p class="font-medium text-sm group-hover:text-amber-500 transition-colors">
                              {producer.name}
                            </p>
                            {formatAgeDisplay(producer) && (
                              <p class="text-xs text-muted-foreground/70">
                                {formatAgeDisplay(producer)}
                              </p>
                            )}
                          </div>
                        </a>
                      )}
                      {writer && (
                        <a
                          href={`/people/${writer.id}`}
                          class="group flex items-center gap-3 rounded-lg p-1 -m-1 hover:bg-muted/50 transition-colors"
                        >
                          <div class="h-10 w-10 shrink-0 overflow-hidden rounded-lg bg-muted">
                            {writer.photoUrl ? (
                              <img
                                src={writer.photoUrl}
                                alt={writer.name}
                                class="h-full w-full object-cover"
                                loading="lazy"
                              />
                            ) : (
                              <div class="flex h-full w-full items-center justify-center text-xs font-semibold text-muted-foreground">
                                {writer.name.charAt(0)}
                              </div>
                            )}
                          </div>
                          <div>
                            <p class="text-xs text-muted-foreground">Writer</p>
                            <p class="font-medium text-sm group-hover:text-amber-500 transition-colors">
                              {writer.name}
                            </p>
                            {formatAgeDisplay(writer) && (
                              <p class="text-xs text-muted-foreground/70">
                                {formatAgeDisplay(writer)}
                              </p>
                            )}
                          </div>
                        </a>
                      )}
                      {cinematographer && (
                        <a
                          href={`/people/${cinematographer.id}`}
                          class="group flex items-center gap-3 rounded-lg p-1 -m-1 hover:bg-muted/50 transition-colors"
                        >
                          <div class="h-10 w-10 shrink-0 overflow-hidden rounded-lg bg-muted">
                            {cinematographer.photoUrl ? (
                              <img
                                src={cinematographer.photoUrl}
                                alt={cinematographer.name}
                                class="h-full w-full object-cover"
                                loading="lazy"
                              />
                            ) : (
                              <div class="flex h-full w-full items-center justify-center text-xs font-semibold text-muted-foreground">
                                {cinematographer.name.charAt(0)}
                              </div>
                            )}
                          </div>
                          <div>
                            <p class="text-xs text-muted-foreground">
                              Cinematographer
                            </p>
                            <p class="font-medium text-sm group-hover:text-amber-500 transition-colors">
                              {cinematographer.name}
                            </p>
                            {formatAgeDisplay(cinematographer) && (
                              <p class="text-xs text-muted-foreground/70">
                                {formatAgeDisplay(cinematographer)}
                              </p>
                            )}
                          </div>
                        </a>
                      )}
                    </div>
                  </div>
                )}
              </div>
            </div>
          </div>

          <TopCast cast={cast} />

          <Separator />

          {/* Accordion Sections */}
          <Accordion type="multiple" class="space-y-2">
            {/* Where to Watch */}
            {movie.whereToWatch && (
              <AccordionItem
                value="where-to-watch"
                class="rounded-lg border border-border bg-card px-4 last:border-b"
              >
                <AccordionTrigger>
                  <span class="text-lg font-medium">Where to Watch</span>
                </AccordionTrigger>
                <AccordionContent>
                  <WhereToWatch whereToWatch={movie.whereToWatch} />
                </AccordionContent>
              </AccordionItem>
            )}

            {/* Full Cast & Crew */}
            {cast.length > 0 && (
              <AccordionItem
                value="full-cast"
                class="rounded-lg border border-border bg-card px-4 last:border-b"
              >
                <AccordionTrigger>
                  <span class="text-lg font-medium">Full Cast & Crew</span>
                </AccordionTrigger>
                <AccordionContent>
                  <div class="space-y-6">
                    {/* Full Cast */}
                    <div>
                      <h3 class="text-sm font-medium text-muted-foreground mb-3">
                        Cast ({cast.length})
                      </h3>
                      <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3">
                        {cast.map((person) => (
                          <a
                            href={`/people/${person.id}`}
                            class="group flex items-center gap-3 p-2 rounded-lg hover:bg-muted/50 transition-colors"
                          >
                            <div class="h-10 w-10 shrink-0 overflow-hidden rounded-lg bg-muted">
                              {person.photoUrl ? (
                                <img
                                  src={person.photoUrl}
                                  alt={person.name}
                                  class="h-full w-full object-cover"
                                  loading="lazy"
                                />
                              ) : (
                                <div class="flex h-full w-full items-center justify-center text-xs font-semibold text-muted-foreground">
                                  {person.name.charAt(0)}
                                </div>
                              )}
                            </div>
                            <div class="min-w-0 flex-1">
                              <p class="font-medium text-sm truncate group-hover:text-amber-500 transition-colors">
                                {person.name}
                              </p>
                              {person.role && (
                                <p class="text-xs text-muted-foreground truncate">
                                  {person.role}
                                </p>
                              )}
                              {formatAgeDisplay(person) && (
                                <p class="text-xs text-muted-foreground/70">
                                  {formatAgeDisplay(person)}
                                </p>
                              )}
                            </div>
                          </a>
                        ))}
                      </div>
                    </div>

                    <CrewGrid
                      title="Directors"
                      people={movie.credits?.directors || []}
                    />
                    <CrewGrid
                      title="Writers"
                      people={movie.credits?.writers || []}
                    />
                    <CrewGrid
                      title="Producers"
                      people={movie.credits?.producers || []}
                    />
                    <CrewGrid
                      title="Composers"
                      people={movie.credits?.composers || []}
                    />
                    <CrewGrid
                      title="Editors"
                      people={movie.credits?.editors || []}
                    />
                    <CrewGrid
                      title="Cinematographers"
                      people={movie.credits?.cinematographers || []}
                    />

                    <AccordionCloseButton label="Close Cast & Crew" />
                  </div>
                </AccordionContent>
              </AccordionItem>
            )}

            {/* More Info */}
            <AccordionItem
              value="more-info"
              class="rounded-lg border border-border bg-card px-4 last:border-b"
            >
              <AccordionTrigger>
                <span class="text-lg font-medium">More Info</span>
              </AccordionTrigger>
              <AccordionContent>
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4 text-sm">
                  {movie.originalTitle &&
                    movie.originalTitle !== movie.title && (
                      <div>
                        <p class="text-muted-foreground">Original Title</p>
                        <p class="font-medium">{movie.originalTitle}</p>
                      </div>
                    )}
                  {movie.originalLanguage && (
                    <div>
                      <p class="text-muted-foreground">Original Language</p>
                      <p class="font-medium uppercase">
                        {movie.originalLanguage}
                      </p>
                    </div>
                  )}
                  {movie.spokenLanguages &&
                    movie.spokenLanguages.length > 0 && (
                      <div>
                        <p class="text-muted-foreground">Spoken Languages</p>
                        <p class="font-medium">
                          {movie.spokenLanguages.join(', ')}
                        </p>
                      </div>
                    )}
                  {movie.productionCountries &&
                    movie.productionCountries.length > 0 && (
                      <div>
                        <p class="text-muted-foreground">
                          Production Countries
                        </p>
                        <p class="font-medium">
                          {movie.productionCountries.join(', ')}
                        </p>
                      </div>
                    )}
                  {movie.productionCompanies &&
                    movie.productionCompanies.length > 0 && (
                      <div class="md:col-span-2">
                        <p class="text-muted-foreground">
                          Production Companies
                        </p>
                        <p class="font-medium">
                          {movie.productionCompanies.join(', ')}
                        </p>
                      </div>
                    )}
                  {movie.imdbID && (
                    <div>
                      <p class="text-muted-foreground">IMDB</p>
                      <a
                        href={`https://www.imdb.com/title/${movie.imdbID}`}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="font-medium text-primary hover:underline"
                      >
                        {movie.imdbID}
                      </a>
                    </div>
                  )}
                </div>
              </AccordionContent>
            </AccordionItem>
          </Accordion>
        </div>
      )
    }
  </main>
</Layout>
