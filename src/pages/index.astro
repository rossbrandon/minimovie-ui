---

<Layout title="MiniMovie">
  <div class="min-h-screen flex flex-col">
    <header class="absolute top-4 right-4 z-10">
      <ThemeToggle />
    </header>

    <main
      class="flex-1 flex flex-col items-center justify-center px-4 py-16 pb-72"
    >
      <div class="w-full max-w-2xl mx-auto text-center space-y-8">
        <div class="space-y-3">
          <div class="flex items-center justify-center gap-3">
            <IconMovie class="h-10 w-10 text-amber-500" />
            <h1 class="text-4xl md:text-5xl font-bold tracking-tight">
              MiniMovie
            </h1>
          </div>
          <p class="text-muted-foreground text-lg">
            Minimal, yet interesting film database
          </p>
        </div>

        <form action="/search" method="GET" class="w-full max-w-xl mx-auto">
          <div
            class="relative flex items-center gap-0 bg-white/10 dark:bg-white/5 backdrop-blur-xl border border-white/20 dark:border-white/10 rounded-xl p-1.5 shadow-lg ring-1 ring-black/5 dark:ring-white/5"
          >
            <IconSearch class="ml-3 h-5 w-5 text-muted-foreground shrink-0" />
            <input
              type="search"
              name="q"
              placeholder="What are you watching?"
              class="flex-1 bg-transparent border-0 outline-none px-3 py-2 text-base sm:text-lg text-foreground placeholder:text-muted-foreground focus:ring-0 focus:outline-none"
              autofocus
            />
            <button
              type="submit"
              class="px-6 py-2.5 bg-amber-500 hover:bg-amber-400 text-black font-medium rounded-lg transition-all shrink-0"
            >
              Search
            </button>
          </div>
        </form>
      </div>
    </main>

