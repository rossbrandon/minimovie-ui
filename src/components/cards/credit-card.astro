---
import { IconStar } from '@components/icons';
import type { FilmCredit } from '@lib/types';
import {
  calculateAgeAtDate,
  formatAgeDisplay,
  formatRating,
  formatYear,
  getInitials,
  resizeImageUrl,
} from '@lib/utils';

interface Props {
  credit: FilmCredit;
  mediaType: 'movie' | 'series';
  voteAverage?: number;
  personBirthday?: string;
  personDeathday?: string;
  personCurrentAge?: number;
  prefetch?: boolean;
}

const {
  credit,
  mediaType,
  voteAverage,
  personBirthday,
  personDeathday,
  personCurrentAge,
  prefetch = false,
} = Astro.props;

const rating = formatRating(voteAverage);

const href =
  mediaType === 'movie' ? `/movies/${credit.id}` : `/series/${credit.id}`;
const year = formatYear(credit.releaseDate);
const initials = getInitials(credit.title);
const posterUrl = resizeImageUrl(credit.posterUrl, 'w342');

const ageAtRelease =
  personBirthday && credit.releaseDate
    ? calculateAgeAtDate(personBirthday, credit.releaseDate)
    : null;

const ageDisplay = formatAgeDisplay({
  ageAtRelease: ageAtRelease ?? undefined,
  currentAge: personCurrentAge,
  birthday: personBirthday,
  deathday: personDeathday,
});
---

<a
  href={href}
  class="group flex flex-col overflow-hidden rounded-lg border border-border bg-card transition-colors hover:bg-accent/50"
  data-astro-prefetch={prefetch ? '' : undefined}
>
  <div class="relative aspect-2/3 overflow-hidden bg-muted">
    {
      posterUrl ? (
        <img
          src={posterUrl}
          alt={credit.title}
          class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105"
          loading="lazy"
        />
      ) : (
        <div class="flex h-full w-full items-center justify-center text-2xl font-semibold text-muted-foreground">
          {initials}
        </div>
      )
    }
  </div>

  <div class="flex flex-col gap-1 p-3">
    <h3
      class="font-medium leading-tight line-clamp-2 text-sm group-hover:text-amber-500 transition-colors"
    >
      {credit.title}
    </h3>
    <div class="flex items-center gap-2 text-xs text-muted-foreground">
      {year && <span>{year}</span>}
      {
        rating && (
          <span class="flex items-center gap-0.5 text-amber-500/80">
            <IconStar class="h-3 w-3" />
            {voteAverage?.toFixed(1)}
          </span>
        )
      }
    </div>
    {
      (credit.role || credit.episodeCount) && (
        <p class="text-xs text-muted-foreground italic">
          {credit.role ? (credit.type === 'cast' ? `as ${credit.role}` : credit.role) : ''}
        </p>
        <p class="text-xs text-muted-foreground italic">
          {credit.episodeCount ? `${credit.episodeCount} ep${credit.episodeCount !== 1 ? 's' : ''}` : ''}
        </p>
      )
    }
    <div class="flex items-center gap-2 text-xs text-muted-foreground">
      {ageDisplay && <span class="text-muted-foreground/70">{ageDisplay}</span>}
    </div>
  </div>
</a>
