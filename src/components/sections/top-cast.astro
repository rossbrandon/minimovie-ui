---
import { PersonCard } from '@components/cards';
import type { Person } from '@lib/types';

interface Props {
  cast: Person[];
  limit?: number;
}

const { cast, limit = 12 } = Astro.props;

const topCast = cast.slice(0, limit);
---

{
  topCast.length > 0 && (
    <div class="grid grid-cols-[repeat(auto-fill,minmax(100px,1fr))] gap-4 pt-1">
      {topCast.map((person) => (
        <PersonCard
          id={person.id}
          name={person.name}
          photoUrl={person.photoUrl}
          role={person.role}
          birthday={person.birthday}
          deathday={person.deathday}
          ageAtRelease={person.ageAtRelease}
          currentAge={person.currentAge}
          ageRange={person.ageRange}
          prefetch={true}
        />
      ))}
    </div>
  )
}
