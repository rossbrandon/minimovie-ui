---
import type { Person } from '@lib/types';
import { formatAgeDisplay } from '@lib/utils';

interface Props {
  title: string;
  people: Person[];
}

const { title, people } = Astro.props;
---

{
  people.length > 0 && (
    <div>
      <h3 class="text-sm font-medium text-muted-foreground mb-3">{title}</h3>
      <div class="flex flex-wrap gap-3">
        {people.map((person) => (
          <a
            href={`/people/${person.id}`}
            class="group flex items-center gap-2 p-2 rounded-lg hover:bg-muted/50 transition-colors"
          >
            <div class="h-8 w-8 shrink-0 overflow-hidden rounded-lg bg-muted">
              {person.photoUrl ? (
                <img
                  src={person.photoUrl}
                  alt={person.name}
                  class="h-full w-full object-cover"
                  loading="lazy"
                />
              ) : (
                <div class="flex h-full w-full items-center justify-center text-xs font-semibold text-muted-foreground">
                  {person.name.charAt(0)}
                </div>
              )}
            </div>
            <div>
              <span class="text-sm font-medium group-hover:text-amber-500 transition-colors">
                {person.name}
              </span>
              {person.role && (
                <p class="text-xs text-muted-foreground">{person.role}</p>
              )}
              {formatAgeDisplay(person) && (
                <p class="text-xs text-muted-foreground/70">
                  {formatAgeDisplay(person)}
                </p>
              )}
            </div>
          </a>
        ))}
      </div>
    </div>
  )
}
