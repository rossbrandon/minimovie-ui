---
import IconSearch from '@tabler/icons/outline/search.svg';
import IconX from '@tabler/icons/outline/x.svg';

interface Props {
  placeholder?: string;
}

const { placeholder = 'Search by name or character...' } = Astro.props;
---

<div class="accordion-search-wrapper relative">
  <IconSearch
    class="absolute left-3 top-1/2 -translate-y-1/2 h-4 w-4 text-muted-foreground pointer-events-none"
  />
  <input
    type="text"
    placeholder={placeholder}
    class="accordion-search-input w-full rounded-md border border-input bg-transparent pl-9 pr-9 py-2 text-sm placeholder:text-muted-foreground focus-visible:border-outline focus-visible:ring-outline/50 focus-visible:ring-3 transition-[color,box-shadow]"
  />
  <button
    type="button"
    class="accordion-search-clear absolute right-2 top-1/2 -translate-y-1/2 h-5 w-5 items-center justify-center rounded-sm text-muted-foreground hover:text-foreground transition-colors hidden"
  >
    <IconX class="h-4 w-4" />
  </button>
</div>
<div class="accordion-search-no-results hidden text-center py-6 text-sm text-muted-foreground">
  No results found
</div>

<script>
  const init = () => {
    document
      .querySelectorAll<HTMLInputElement>('.accordion-search-input')
      .forEach((input) => {
        if (input.dataset.initialized) return;
        input.dataset.initialized = 'true';

        const wrapper = input.closest('.accordion-search-wrapper');
        const container = wrapper?.parentElement;
        if (!container) return;

        const clearBtn =
          wrapper?.querySelector<HTMLButtonElement>('.accordion-search-clear');
        const noResults = container.querySelector(
          '.accordion-search-no-results'
        );

        const filterContent = () => {
          const query = input.value.toLowerCase().trim();
          let totalVisible = 0;

          if (clearBtn) {
            clearBtn.classList.toggle('hidden', !query);
            clearBtn.classList.toggle('flex', !!query);
          }

          Array.from(container.children).forEach((child) => {
            if (!(child instanceof HTMLElement)) return;
            if (
              child.classList.contains('accordion-search-wrapper') ||
              child.classList.contains('accordion-search-no-results') ||
              child.classList.contains('starwind-accordion-close-wrapper')
            )
              return;

            const links = child.querySelectorAll<HTMLAnchorElement>('a');
            if (links.length === 0) return;

            let sectionVisible = 0;
            links.forEach((link) => {
              const text = link.textContent?.toLowerCase() || '';
              const match = !query || text.includes(query);
              link.style.display = match ? '' : 'none';
              if (match) sectionVisible++;
            });

            child.style.display = sectionVisible > 0 ? '' : 'none';
            totalVisible += sectionVisible;
          });

          if (noResults) {
            noResults.classList.toggle('hidden', !query || totalVisible > 0);
          }
        };

        input.addEventListener('input', filterContent);

        clearBtn?.addEventListener('click', () => {
          input.value = '';
          filterContent();
          input.focus();
        });
      });
  };

  init();
  document.addEventListener('astro:after-swap', init);
</script>
