<script>
  import ChevronUpSvg from '@tabler/icons/outline/chevron-up.svg?raw';

  let button: HTMLButtonElement | null = null;
  let observer: IntersectionObserver | null = null;

  const createButton = (): HTMLButtonElement => {
    const btn = document.createElement('button');
    btn.type = 'button';
    btn.className = [
      'fixed bottom-4 left-1/2 -translate-x-1/2 z-50',
      'flex items-center justify-center gap-2',
      'px-4 py-2 rounded-full',
      'text-sm font-medium',
      'bg-card/95 backdrop-blur-sm',
      'border border-border shadow-lg',
      'text-muted-foreground hover:text-foreground',
      'transition-all duration-200',
      'opacity-0 pointer-events-none translate-y-4',
    ].join(' ');
    btn.innerHTML = `${ChevronUpSvg}<span>Return to Top</span>`;
    const svg = btn.querySelector('svg');
    if (svg) svg.classList.add('size-4');
    btn.addEventListener('click', () => {
      hide(btn);
      window.scrollTo({ top: 0, behavior: 'smooth' });
    });
    document.body.appendChild(btn);
    return btn;
  };

  const show = (btn: HTMLButtonElement) => {
    btn.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-4');
    btn.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
  };

  const hide = (btn: HTMLButtonElement) => {
    btn.classList.remove('opacity-100', 'pointer-events-auto', 'translate-y-0');
    btn.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
  };

  const setup = () => {
    if (observer) observer.disconnect();
    if (button) {
      button.remove();
      button = null;
    }

    const tabsLists: HTMLElement[] = [];
    document.querySelectorAll<HTMLElement>('.starwind-tabs').forEach((tabs) => {
      if (tabs.closest('[data-tabs-content]')) return;
      const list = tabs.querySelector<HTMLElement>('[data-tabs-list]');
      if (list) tabsLists.push(list);
    });

    if (tabsLists.length === 0) return;

    const btn = createButton();
    button = btn;

    const offScreen = new Set<HTMLElement>();

    observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          const target = entry.target as HTMLElement;
          if (!entry.isIntersecting && entry.boundingClientRect.top < 0) {
            offScreen.add(target);
          } else {
            offScreen.delete(target);
          }
        });
        if (offScreen.size > 0) show(btn);
        else hide(btn);
      },
      { threshold: 0 }
    );

    tabsLists.forEach((list) => observer!.observe(list));
  };

  setup();
  document.addEventListener('astro:after-swap', setup);
</script>
