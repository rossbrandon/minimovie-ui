---
import { CreditCard } from '@components/cards';
import type { CollectionInfo } from '@lib/types';

interface Props {
  collection: CollectionInfo;
}

const { collection } = Astro.props;

const sortedParts = [...(collection.parts || [])].sort((a, b) => {
  if (!a.releaseDate) return 1;
  if (!b.releaseDate) return -1;
  return a.releaseDate.localeCompare(b.releaseDate);
});
---

<div class="space-y-4">
  {
    collection.overview && (
      <p class="text-sm text-muted-foreground leading-relaxed">
        {collection.overview}
      </p>
    )
  }

  <div class="grid grid-cols-[repeat(auto-fill,minmax(140px,1fr))] gap-4">
    {
      sortedParts.map((part) => (
        <CreditCard
          credit={{
            id: part.id,
            title: part.title,
            posterUrl: part.posterUrl,
            releaseDate: part.releaseDate,
            type: 'cast',
          }}
          mediaType="movie"
          voteAverage={part.voteAverage}
        />
      ))
    }
  </div>
</div>
