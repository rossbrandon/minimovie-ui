---
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

type Props = Omit<HTMLAttributes<'div'>, 'role'>;

export const tabsList = tv({
  base: 'starwind-tabs-list text-muted-foreground flex w-full items-center gap-1 border-b border-border overflow-x-auto overflow-y-hidden scroll-px-8',
});

const { class: className, ...rest } = Astro.props;
---

<div class="starwind-tabs-list-anchor relative">
  <div
    class={tabsList({ class: className })}
    data-slot="tabs-list"
    data-tabs-list
    role="tablist"
    {...rest}
  >
    <slot />
  </div>
</div>

<script>
  const setupScrollIndicators = () => {
    document
      .querySelectorAll<HTMLElement>('.starwind-tabs-list')
      .forEach((list) => {
        if (list.dataset.scrollInit) return;
        list.dataset.scrollInit = 'true';

        list.style.scrollbarWidth = 'none';

        const anchor = list.closest('.starwind-tabs-list-anchor');
        if (!anchor) return;

        const hintRight = document.createElement('div');
        hintRight.className = 'starwind-tabs-scroll-hint starwind-tabs-scroll-hint--end';
        hintRight.setAttribute('aria-hidden', 'true');
        anchor.appendChild(hintRight);

        const hintLeft = document.createElement('div');
        hintLeft.className = 'starwind-tabs-scroll-hint starwind-tabs-scroll-hint--start';
        hintLeft.setAttribute('aria-hidden', 'true');
        anchor.appendChild(hintLeft);

        const update = () => {
          const canScroll = list.scrollWidth > list.clientWidth;
          const atEnd =
            list.scrollLeft + list.clientWidth >= list.scrollWidth - 1;
          const atStart = list.scrollLeft <= 1;

          hintRight.classList.toggle('visible', canScroll && !atEnd);
          hintLeft.classList.toggle('visible', canScroll && !atStart);
        };

        list.addEventListener('scroll', update, { passive: true });
        new ResizeObserver(update).observe(list);
        update();
      });
  };

  setupScrollIndicators();
  document.addEventListener('astro:after-swap', setupScrollIndicators);
</script>

<style is:global>
  .starwind-tabs-list::-webkit-scrollbar {
    display: none;
  }

  .starwind-tabs-scroll-hint {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 2rem;
    pointer-events: none;
    opacity: 0;
    transition: opacity 0.2s;
    z-index: 1;
  }

  .starwind-tabs-scroll-hint--end {
    right: 0;
    background: linear-gradient(
      to right,
      transparent,
      var(--color-background) 80%
    );
  }

  .starwind-tabs-scroll-hint--start {
    left: 0;
    background: linear-gradient(
      to left,
      transparent,
      var(--color-background) 80%
    );
  }

  .starwind-tabs-scroll-hint.visible {
    opacity: 1;
  }
</style>
