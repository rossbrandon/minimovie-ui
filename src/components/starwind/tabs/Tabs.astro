---
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

interface Props extends HTMLAttributes<'div'> {
  defaultValue?: string;
  syncKey?: string;
}

export const tabs = tv({ base: 'starwind-tabs' });

const { defaultValue, syncKey, class: className, ...rest } = Astro.props;
---

<div
  class={tabs({ class: className })}
  data-default-value={defaultValue}
  data-sync-key={syncKey}
  data-slot="tabs"
  {...rest}
>
  <slot />
</div>

<script>
  type TabValue = string;

  interface TabsSyncEventDetail {
    value: TabValue;
  }

  interface TabsSyncEvent extends CustomEvent<TabsSyncEventDetail> {
    type: `starwind-tabs-sync:${string}`;
  }

  class TabsHandler {
    private tabs: HTMLElement;
    private triggers: HTMLButtonElement[];
    private contents: HTMLElement[];
    private currentTabIndex: number = 0;
    private tabsId: string;
    private syncKey?: string;
    private storageKey: string;
    private valueToTriggerMap: Map<string, HTMLButtonElement>;
    private valueToContentMap: Map<string, HTMLElement>;
    private parentHandler: TabsHandler | null = null;

    constructor(
      tabs: HTMLElement,
      idx: number,
      parentHandler: TabsHandler | null = null
    ) {
      this.tabs = tabs;
      this.parentHandler = parentHandler;
      this.triggers = Array.from(
        tabs.querySelectorAll(':scope > .starwind-tabs-list-anchor > [data-tabs-list] > [data-tabs-trigger]')
      );
      this.contents = Array.from(
        tabs.querySelectorAll(':scope > [data-tabs-content]')
      );
      this.tabsId = `starwind-tabs${idx}`;
      this.syncKey = tabs.dataset.syncKey;
      this.storageKey = this.syncKey
        ? `starwind-tabs-${this.syncKey}`
        : `starwind-tabs-${this.tabsId}`;

      // Create maps for faster lookups
      this.valueToTriggerMap = new Map(
        this.triggers.map((trigger) => [
          trigger.getAttribute('data-value') ?? '',
          trigger,
        ])
      );
      this.valueToContentMap = new Map(
        this.contents.map((content) => [
          content.getAttribute('data-value') ?? '',
          content,
        ])
      );

      this.setupIds();
      this.initializeTab();
      this.addEventListeners();

      if (this.syncKey) {
        this.setupSyncListener();
      }
    }

    private initializeTab(): void {
      const urlTab = new URLSearchParams(window.location.search).get('tab');
      const value =
        urlTab && this.valueToTriggerMap.has(urlTab)
          ? urlTab
          : this.syncKey
            ? (localStorage.getItem(this.storageKey) ??
              this.tabs.dataset.defaultValue)
            : this.tabs.dataset.defaultValue;

      if (value) {
        this.showTab(value, true);
        this.currentTabIndex = this.triggers.findIndex(
          (trigger) => trigger.getAttribute('data-value') === value
        );
        this.setTabIndex();
      }
    }

    private setupSyncListener(): void {
      document.addEventListener(`starwind-tabs-sync:${this.syncKey}`, ((
        e: TabsSyncEvent
      ) => {
        const value = e.detail.value;
        const trigger = this.valueToTriggerMap.get(value);
        const index = trigger ? this.triggers.indexOf(trigger) : -1;

        if (index !== -1) {
          this.showTab(value);
          this.currentTabIndex = index;
          this.setTabIndex();
        }
      }) as EventListener);
    }

    private setupIds(): void {
      this.triggers.forEach((trigger, idx) => {
        const triggerId = `${this.tabsId}-t${idx}`;
        const contentId = `${this.tabsId}-c${idx}`;
        const value = trigger.getAttribute('data-value');

        trigger.id = triggerId;

        if (value) {
          trigger.setAttribute('aria-controls', contentId);
          const content = this.valueToContentMap.get(value);
          if (content) {
            content.id = contentId;
            content.setAttribute('aria-labelledby', triggerId);
          }
        }
      });
    }

    private setTabIndex(): void {
      this.triggers.forEach((trigger, index) => {
        trigger.setAttribute(
          'tabindex',
          index === this.currentTabIndex ? '0' : '-1'
        );
      });
    }

    private dispatchSyncEvent(value: TabValue): void {
      if (!this.syncKey) return;

      document.dispatchEvent(
        new CustomEvent(`starwind-tabs-sync:${this.syncKey}`, {
          detail: { value },
        })
      );

      localStorage.setItem(this.storageKey, value);
    }

    private handleKeyNavigation = (e: KeyboardEvent): void => {
      const key = e.key;
      let newIndex = this.currentTabIndex;

      switch (key) {
        case 'ArrowRight': {
          for (let i = 1; i < this.triggers.length; i++) {
            const index = (this.currentTabIndex + i) % this.triggers.length;
            if (!this.triggers[index].disabled) {
              newIndex = index;
              break;
            }
          }
          break;
        }
        case 'ArrowLeft': {
          for (let i = 1; i < this.triggers.length; i++) {
            const index =
              (this.currentTabIndex - i + this.triggers.length) %
              this.triggers.length;
            if (!this.triggers[index].disabled) {
              newIndex = index;
              break;
            }
          }
          break;
        }
        case 'Home': {
          for (let i = 0; i < this.triggers.length; i++) {
            if (!this.triggers[i].disabled) {
              newIndex = i;
              break;
            }
          }
          break;
        }
        case 'End': {
          for (let i = this.triggers.length - 1; i >= 0; i--) {
            if (!this.triggers[i].disabled) {
              newIndex = i;
              break;
            }
          }
          break;
        }
        default:
          return;
      }

      e.preventDefault();
      const newTrigger = this.triggers[newIndex];
      const value = newTrigger.getAttribute('data-value');
      if (value) {
        this.showTab(value);
        this.currentTabIndex = newIndex;
        this.setTabIndex();
        newTrigger.focus();
        this.dispatchSyncEvent(value);
      }
    };

    private handleClick = (trigger: HTMLElement, index: number): void => {
      const value = trigger.getAttribute('data-value');
      if (value) {
        this.showTab(value);
        this.currentTabIndex = index;
        this.setTabIndex();
        trigger.focus();
        this.dispatchSyncEvent(value);
      }
    };

    private swipeStartX = 0;
    private swipeStartY = 0;
    private swiping = false;
    private directionLocked = false;
    private swipeIgnored = false;
    private peekPanel: HTMLElement | null = null;
    private peekIndex = -1;

    private getAdjacentIndex(direction: number): number {
      for (let i = 1; i < this.triggers.length; i++) {
        const idx = this.currentTabIndex + direction * i;
        if (idx < 0 || idx >= this.triggers.length) return -1;
        if (!this.triggers[idx].disabled) return idx;
      }
      return -1;
    }

    private handleTouchStart = (e: TouchEvent): void => {
      const target = e.target as HTMLElement;
      this.swipeIgnored = !!target.closest('[data-tabs-list]');
      this.swipeStartX = e.touches[0].clientX;
      this.swipeStartY = e.touches[0].clientY;
      this.swiping = false;
      this.directionLocked = false;
      this.peekPanel = null;
      this.peekIndex = -1;
    };

    private handleTouchMove = (e: TouchEvent): void => {
      if (this.swipeIgnored) return;

      const dx = e.touches[0].clientX - this.swipeStartX;
      const dy = e.touches[0].clientY - this.swipeStartY;

      if (!this.directionLocked) {
        if (Math.abs(dx) < 10 && Math.abs(dy) < 10) return;
        this.directionLocked = true;
        if (Math.abs(dy) > Math.abs(dx)) return;
        this.swiping = true;
      }

      if (!this.swiping) return;

      e.preventDefault();

      const direction = dx < 0 ? 1 : -1;
      const adjacentIdx = this.getAdjacentIndex(direction);

      if (adjacentIdx === -1) {
        this.cleanupPeek();
        return;
      }

      const currentPanel = this.contents[this.currentTabIndex];
      if (!currentPanel) return;

      if (this.peekIndex !== adjacentIdx) {
        this.cleanupPeek();
        this.peekPanel = this.contents[adjacentIdx];
        this.peekIndex = adjacentIdx;

        if (this.peekPanel) {
          const parent = currentPanel.parentElement!;
          parent.style.position = 'relative';
          parent.style.overflow = 'hidden';

          const panelRect = currentPanel.getBoundingClientRect();
          const parentRect = parent.getBoundingClientRect();
          const exactTop = panelRect.top - parentRect.top;

          this.peekPanel.style.position = 'absolute';
          this.peekPanel.style.top = `${exactTop}px`;
          this.peekPanel.style.marginTop = '0';
          this.peekPanel.style.left = '0';
          this.peekPanel.style.right = '0';
          this.peekPanel.hidden = false;
          this.peekPanel.style.willChange = 'transform';
        }
      }

      const gap = 16;

      currentPanel.style.willChange = 'transform';
      currentPanel.style.transform = `translateX(${dx}px)`;

      if (this.peekPanel) {
        const w = currentPanel.offsetWidth;
        const offset = direction < 0 ? -(w + gap) + dx : w + gap + dx;
        this.peekPanel.style.transform = `translateX(${offset}px)`;
      }
    };

    private handleTouchEnd = (e: TouchEvent): void => {
      if (!this.swiping) {
        this.cleanupPeek();
        return;
      }

      const dx = e.changedTouches[0].clientX - this.swipeStartX;
      const currentPanel = this.contents[this.currentTabIndex];
      const threshold = (currentPanel?.offsetWidth ?? 300) * 0.25;
      const commit = Math.abs(dx) > threshold && this.peekPanel;

      if (commit && this.peekPanel && currentPanel) {
        const w = currentPanel.offsetWidth;
        const gap = 16;
        const direction = dx < 0 ? 1 : -1;
        const dur = '200ms';

        currentPanel.style.transition = `transform ${dur} ease-out`;
        currentPanel.style.transform = `translateX(${-direction * (w + gap)}px)`;

        this.peekPanel.style.transition = `transform ${dur} ease-out`;
        this.peekPanel.style.transform = 'translateX(0)';

        const peekPanel = this.peekPanel;
        const peekIdx = this.peekIndex;

        const onEnd = () => {
          currentPanel.removeEventListener('transitionend', onEnd);
          this.resetStyles(currentPanel);
          this.resetStyles(peekPanel);
          if (currentPanel.parentElement) {
            currentPanel.parentElement.style.position = '';
            currentPanel.parentElement.style.overflow = '';
          }

          const value = this.triggers[peekIdx]?.getAttribute('data-value');
          if (value) {
            this.showTab(value);
            this.currentTabIndex = peekIdx;
            this.setTabIndex();
            this.dispatchSyncEvent(value);
          }

          this.peekPanel = null;
          this.peekIndex = -1;
        };

        currentPanel.addEventListener('transitionend', onEnd, { once: true });
        setTimeout(onEnd, 250);
      } else {
        this.snapBack(currentPanel);
      }

      this.swiping = false;
      this.directionLocked = false;
    };

    private snapBack(currentPanel: HTMLElement | undefined): void {
      if (currentPanel) {
        currentPanel.style.transition = 'transform 200ms ease-out';
        currentPanel.style.transform = '';

        currentPanel.addEventListener(
          'transitionend',
          () => this.resetStyles(currentPanel),
          { once: true }
        );
      }

      if (this.peekPanel) {
        const w = currentPanel?.offsetWidth ?? 300;
        const gap = 16;
        const direction = this.peekIndex > this.currentTabIndex ? 1 : -1;
        this.peekPanel.style.transition = 'transform 200ms ease-out';
        this.peekPanel.style.transform = `translateX(${direction * (w + gap)}px)`;

        const peek = this.peekPanel;
        peek.addEventListener(
          'transitionend',
          () => {
            this.resetStyles(peek);
            peek.hidden = true;
            if (currentPanel?.parentElement) {
              currentPanel.parentElement.style.position = '';
              currentPanel.parentElement.style.overflow = '';
            }
          },
          { once: true }
        );
      }

      this.peekPanel = null;
      this.peekIndex = -1;
    }

    private resetStyles(el: HTMLElement): void {
      el.style.transform = '';
      el.style.transition = '';
      el.style.willChange = '';
      el.style.position = '';
      el.style.top = '';
      el.style.marginTop = '';
      el.style.left = '';
      el.style.right = '';
    }

    private cleanupPeek(): void {
      if (this.peekPanel) {
        this.resetStyles(this.peekPanel);
        this.peekPanel.hidden = true;
        this.peekPanel = null;
        this.peekIndex = -1;
      }

      const currentPanel = this.contents[this.currentTabIndex];
      if (currentPanel) {
        this.resetStyles(currentPanel);
        if (currentPanel.parentElement) {
          currentPanel.parentElement.style.position = '';
          currentPanel.parentElement.style.overflow = '';
        }
      }
    }

    private addEventListeners(): void {
      this.triggers.forEach((trigger, index) => {
        trigger.addEventListener('click', () =>
          this.handleClick(trigger, index)
        );
        trigger.addEventListener('keydown', (e) => this.handleKeyNavigation(e));
      });

      this.tabs.addEventListener('touchstart', this.handleTouchStart, {
        passive: true,
      });
      this.tabs.addEventListener('touchmove', this.handleTouchMove, {
        passive: false,
      });
      this.tabs.addEventListener('touchend', this.handleTouchEnd);
    }

    private showTab(value: TabValue, isInit = false): void {
      const trigger = this.valueToTriggerMap.get(value);
      const content = this.valueToContentMap.get(value);

      if (!trigger || !content) return;

      this.triggers.forEach((t) => {
        const isActive = t === trigger;
        t.setAttribute('data-state', isActive ? 'active' : 'inactive');
        t.setAttribute('aria-selected', isActive.toString());
      });

      this.contents.forEach((c) => {
        const isActive = c === content;
        c.setAttribute('data-state', isActive ? 'active' : 'inactive');
        c.hidden = !isActive;
      });

      trigger.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'nearest' });

      if (!isInit) {
        const url = new URL(window.location.href);
        url.searchParams.set('tab', value);
        history.replaceState(null, '', url.toString());
      }

      if (
        content.hasAttribute('data-state') &&
        content.getAttribute('data-state') === 'active'
      ) {
        const nestedTabs =
          content.querySelectorAll<HTMLElement>('.starwind-tabs');

        nestedTabs.forEach((nestedTab, nestedIdx) => {
          if (!tabInstances.has(nestedTab)) {
            const uniqueIdx = 1000 + nestedIdx;
            const handler = new TabsHandler(nestedTab, uniqueIdx, this);
            tabInstances.set(nestedTab, handler);
          }
        });
      }
    }
  }

  // Store instances in a WeakMap to avoid memory leaks
  const tabInstances = new WeakMap<HTMLElement, TabsHandler>();

  const setupTabs = () => {
    // First handle top-level tabs
    document
      .querySelectorAll<HTMLElement>('.starwind-tabs')
      .forEach((tabs, idx) => {
        // Skip tabs that are nested within other tab contents
        const isNested = !!tabs.closest('[data-tabs-content]');
        if (!isNested && !tabInstances.has(tabs)) {
          tabInstances.set(tabs, new TabsHandler(tabs, idx));
        }
      });
  };

  setupTabs();
  document.addEventListener('astro:after-swap', setupTabs);
</script>
