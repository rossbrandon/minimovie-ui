---
import type { HTMLAttributes } from 'astro/types';
import { tv } from 'tailwind-variants';

import ChevronUp from '@tabler/icons/outline/chevron-up.svg';

type Props = HTMLAttributes<'div'> & {
  label?: string;
};

export const accordionCloseButton = tv({
  base: 'starwind-accordion-close-wrapper',
});

const { label = 'Close section', class: className, ...rest } = Astro.props;
---

<div
  class={accordionCloseButton({ class: className })}
  data-label={label}
  {...rest}
>
  <!-- This is a marker element; the actual button is created via JS and fixed to viewport -->
</div>

<script>
  import ChevronUpSvg from '@tabler/icons/outline/chevron-up.svg?raw';

  const buttonStates = new WeakSet<HTMLElement>();

  const createFixedButton = (label: string): HTMLButtonElement => {
    const button = document.createElement('button');
    button.type = 'button';
    button.className = [
      'fixed bottom-4 left-1/2 -translate-x-1/2 z-50',
      'flex items-center justify-center gap-2',
      'px-4 py-2 rounded-full',
      'text-sm font-medium',
      'bg-card/95 backdrop-blur-sm',
      'border border-border shadow-lg',
      'text-muted-foreground hover:text-foreground',
      'transition-all duration-200',
      'opacity-0 pointer-events-none translate-y-4',
    ].join(' ');
    button.innerHTML = `${ChevronUpSvg}<span>${label}</span>`;
    const svg = button.querySelector('svg');
    if (svg) {
      svg.classList.add('size-4');
    }
    return button;
  };

  const showButton = (button: HTMLButtonElement) => {
    button.classList.remove(
      'opacity-0',
      'pointer-events-none',
      'translate-y-4'
    );
    button.classList.add('opacity-100', 'pointer-events-auto', 'translate-y-0');
  };

  const hideButton = (button: HTMLButtonElement) => {
    button.classList.remove(
      'opacity-100',
      'pointer-events-auto',
      'translate-y-0'
    );
    button.classList.add('opacity-0', 'pointer-events-none', 'translate-y-4');
  };

  const setupCloseButtons = () => {
    document
      .querySelectorAll<HTMLElement>('.starwind-accordion-close-wrapper')
      .forEach((wrapper) => {
        if (buttonStates.has(wrapper)) return;

        const accordionItem = wrapper.closest<HTMLElement>(
          '.starwind-accordion-item'
        );
        const trigger = accordionItem?.querySelector<HTMLElement>(
          '.starwind-accordion-trigger'
        );

        if (!accordionItem || !trigger) return;

        const label = wrapper.dataset.label || 'Close section';
        const fixedButton = createFixedButton(label);
        document.body.appendChild(fixedButton);

        const updateVisibility = () => {
          const isOpen = accordionItem.getAttribute('data-state') === 'open';
          if (isOpen) {
            showButton(fixedButton);
          } else {
            hideButton(fixedButton);
          }
        };

        // Check initial state
        updateVisibility();

        // Watch for accordion state changes
        const stateObserver = new MutationObserver(updateVisibility);
        stateObserver.observe(accordionItem, {
          attributes: true,
          attributeFilter: ['data-state'],
        });

        fixedButton.addEventListener('click', () => {
          if (accordionItem.getAttribute('data-state') === 'open') {
            trigger.click();
            trigger.scrollIntoView({ behavior: 'smooth', block: 'start' });
          }
        });

        buttonStates.add(wrapper);
      });
  };

  setupCloseButtons();
  document.addEventListener('astro:after-swap', setupCloseButtons);
</script>
