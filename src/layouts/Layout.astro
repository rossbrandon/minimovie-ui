---
import { Font } from 'astro:assets';
import { Footer } from '@components/layout';

import '@styles/starwind.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'MiniMovie', description = 'A minimalistic movie database' } =
  Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <Font cssVariable="--font-sans" preload />
    <title>{title}</title>
    <script is:inline>
      // Only set data-theme if user has explicitly chosen a theme
      const localStorageTheme = localStorage?.getItem('theme') ?? '';
      if (['dark', 'light'].includes(localStorageTheme)) {
        document.documentElement.setAttribute('data-theme', localStorageTheme);
      }
      // Otherwise, let CSS media queries handle it based on system preference
    </script>
  </head>
  <body
    class="min-h-screen bg-background text-foreground antialiased flex flex-col"
  >
    <slot />
    <Footer />
  </body>
</html>

<style is:global>
  body {
    font-family: var(--font-sans);
  }
</style>
